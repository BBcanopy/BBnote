{
  "name": "bbnote",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "web",
    "server",
    "android"
  ],
  "scripts": {
    "dev": "concurrently \"npm:dev --workspace server\" \"npm:dev --workspace web\"",
    "build": "npm run build --workspace web && npm run build --workspace server",
    "test": "npm run test --workspace server && npm run test --workspace web",
    "test:server": "npm run test --workspace server",
    "test:web": "npm run test --workspace web",
    "test:e2e": "playwright test",
    "server:consistency-check": "npm run cli --workspace server -- consistency-check"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.2",
    "concurrently": "^9.2.1",
    "typescript": "^5.9.2"
  }
}

