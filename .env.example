# Host port for the public web app
APP_HOST_PORT=8080

# Your public-facing app URL
# Keep this aligned with the web URL users open in their browser.
APP_BASE_URL=http://localhost:8080

# Optional direct host port for the server when using the split web/server compose stack.
# The all-in-one compose file does not use this.
SERVER_HOST_PORT=3000

# Session secret used by the server.
# Replace this with a secret that is at least 32 characters long.
SESSION_SECRET=bbnote-dev-session-secret-0123456789

# OIDC config
# For local mock auth, keep MOCK_OIDC_ENABLED=true and point the issuer back at the app URL.
OIDC_ISSUER_URL=http://localhost:8080/mock-oidc
OIDC_CLIENT_ID_WEB=bbnote-web
OIDC_CLIENT_ID_ANDROID=bbnote-android
OIDC_CLIENT_SECRET=bbnote-dev-client-secret
OIDC_SCOPES=openid profile email

# Storage paths inside the container.
# These usually do not need to change unless you customize the image layout.
SQLITE_PATH=/data/db/bbnote.sqlite
NOTES_ROOT=/data/notes
ATTACHMENTS_ROOT=/data/attachments
EXPORTS_ROOT=/data/exports

# Enable the built-in mock OIDC provider for local smoke tests.
# Set this to false when pointing at a real OIDC issuer.
MOCK_OIDC_ENABLED=true

# Optional, but recommended, if you want mounted files owned by your host user.
BBNOTE_UID=1000
BBNOTE_GID=1000
