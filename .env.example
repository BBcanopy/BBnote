# Host port for the public web app
APP_HOST_PORT=8082

# Your public-facing app URL
APP_BASE_URL=http://localhost:8082

# Session secret used by the server.
# Replace this with a secret that is at least 32 characters long.
SESSION_SECRET=replace-with-a-32-character-secret-minimum

# OIDC config
# Use your real provider issuer URL.
# The redirect URI should be ${APP_BASE_URL}/auth/callback for the web client.
OIDC_ISSUER_URL=https://your-issuer.example.com
OIDC_CLIENT_ID_WEB=bbnote-web
OIDC_CLIENT_ID_ANDROID=bbnote-android
OIDC_CLIENT_SECRET=replace-with-your-client-secret
OIDC_SCOPES=openid profile email

# Storage paths inside the container.
SQLITE_PATH=/data/db/bbnote.sqlite
NOTES_ROOT=/data/notes
ATTACHMENTS_ROOT=/data/attachments
EXPORTS_ROOT=/data/exports

# Optional, but recommended
BBNOTE_UID=1000
BBNOTE_GID=1000

# You don't need these if you run all-in-one image
SERVER_HOST_PORT=3002
